generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  avatar              String?
  mustChangePassword  Boolean  @default(true)
  isAdmin             Boolean  @default(false)
  displayName         String?
  nickname            String?
  bio                 String?
  nationality         String?
  phone               String?
  emergencyContact    String?
  dietaryRestrictions String?
  allergies           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TripConfig {
  key       String   @id
  startDate DateTime
  endDate   DateTime
  updatedAt DateTime @updatedAt
}

model Hotel {
  id        String   @id @default(cuid())
  name      String
  city      String
  boardPlan String
  rooms     Int
  roomType  String
  checkIn   DateTime
  nights    Int
  imageUrl  String?

  resortFeePerRoomPerNight Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Flight {
  id                 String   @id @default(cuid())
  airline            String
  flightNumber       String
  flightIata         String
  originCode         String
  originCity         String
  originCountry      String
  destinationCode    String
  destinationCity    String
  destinationCountry String
  departureDate      String
  departureTime      String
  arrivalDate        String
  arrivalTime        String
  duration           String
  cabinClass         String
  passengers         Int
  sortOrder          Int      @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
