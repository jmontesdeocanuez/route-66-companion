generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  avatar              String?
  mustChangePassword  Boolean  @default(true)
  isAdmin             Boolean  @default(false)
  displayName         String?
  nickname            String?
  bio                 String?
  nationality         String?
  phone               String?
  emergencyContact    String?
  dietaryRestrictions String?
  allergies           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TripConfig {
  key       String   @id
  startDate DateTime
  endDate   DateTime
  updatedAt DateTime @updatedAt
}

model Hotel {
  id        String   @id @default(cuid())
  name      String
  city      String
  boardPlan String
  rooms     Int
  roomType  String
  checkIn   DateTime
  nights    Int
  imageUrl  String?

  resortFeePerRoomPerNight Int?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  itineraryItems ItineraryItem[]
}

model Flight {
  id                 String   @id @default(cuid())
  airline            String
  flightNumber       String
  flightIata         String
  originCode         String
  originCity         String
  originCountry      String
  destinationCode    String
  destinationCity    String
  destinationCountry String
  departureDate      String
  departureTime      String
  arrivalDate        String
  arrivalTime        String
  duration           String
  cabinClass         String
  passengers         Int
  sortOrder          Int      @default(0)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  itineraryItems ItineraryItem[]
}

model Stop {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  time        String?
  imageUrl    String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  itineraryItems ItineraryItem[]
}

model ItineraryItem {
  id        String   @id @default(cuid())
  date      DateTime
  sortOrder Int      @default(0)
  completed Boolean  @default(false)

  type      String
  flightId  String?
  hotelId   String?
  stopId    String?

  flight    Flight? @relation(fields: [flightId], references: [id])
  hotel     Hotel?  @relation(fields: [hotelId], references: [id])
  stop      Stop?   @relation(fields: [stopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RentalCar {
  id           String   @id @default(cuid())
  licensePlate String
  model        String
  imageUrl     String?
  pickupKm     Int?
  returnKm     Int?

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  refills   FuelRefill[]
}

model FuelRefill {
  id            String    @id @default(cuid())
  carId         String
  car           RentalCar @relation(fields: [carId], references: [id], onDelete: Cascade)
  date          String
  dollars       Float
  pricePerLiter Float
  location      String
  km            Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
