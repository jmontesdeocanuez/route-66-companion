generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  avatar              String?
  mustChangePassword  Boolean  @default(true)
  onboardingCompleted Boolean  @default(false)
  isAdmin             Boolean  @default(false)
  displayName         String?
  nickname            String?
  bio                 String?
  nationality         String?
  phone               String?
  emergencyContact    String?
  dietaryRestrictions String?
  allergies           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  luggageItems        UserLuggageItem[]
}

model LuggageItem {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userItems   UserLuggageItem[]
}

model UserLuggageItem {
  id            String       @id @default(cuid())
  userId        String
  luggageItemId String?
  status        String       // "added" | "discarded"
  packed        Boolean      @default(false)
  name          String
  category      String
  description   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  luggageItem   LuggageItem? @relation(fields: [luggageItemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
}

model TripConfig {
  key       String   @id
  startDate DateTime
  endDate   DateTime
  updatedAt DateTime @updatedAt
}

model Hotel {
  id        String   @id @default(cuid())
  name      String
  city      String
  boardPlan String
  rooms     Int
  roomType  String
  checkIn   DateTime
  nights    Int
  imageUrl  String?

  resortFeePerRoomPerNight Int?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  itineraryItems ItineraryItem[]
}

model Flight {
  id                 String   @id @default(cuid())
  airline            String
  flightNumber       String
  flightIata         String
  originCode         String
  originCity         String
  originCountry      String
  destinationCode    String
  destinationCity    String
  destinationCountry String
  departureDate      String
  departureTime      String
  arrivalDate        String
  arrivalTime        String
  duration           String
  cabinClass         String
  passengers         Int
  sortOrder          Int      @default(0)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  itineraryItems ItineraryItem[]
}

model Stop {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  mapsQuery   String?
  time        String?
  imageUrl    String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  itineraryItems ItineraryItem[]
}

model Excursion {
  id            String   @id @default(cuid())
  emoji         String
  name          String
  date          String
  time          String
  meetingTime   String?
  meetingPoint  String?
  participants  Int
  duration      String?
  details       String[]
  notes         String[]
  nonRefundable Boolean  @default(false)
  sortOrder     Int      @default(0)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  itineraryItems ItineraryItem[]
}

model ItineraryItem {
  id        String   @id @default(cuid())
  date      DateTime
  sortOrder Int      @default(0)
  completed Boolean  @default(false)

  type        String
  noteText    String?
  flightId    String?
  hotelId     String?
  stopId      String?
  excursionId String?

  flight    Flight?    @relation(fields: [flightId], references: [id])
  hotel     Hotel?     @relation(fields: [hotelId], references: [id])
  stop      Stop?      @relation(fields: [stopId], references: [id], onDelete: Cascade)
  excursion Excursion? @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RentalCar {
  id           String   @id @default(cuid())
  licensePlate String
  model        String
  imageUrl     String?
  pickupKm     Int?
  returnKm     Int?

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  refills   FuelRefill[]
}

model FuelRefill {
  id            String    @id @default(cuid())
  carId         String
  car           RentalCar @relation(fields: [carId], references: [id], onDelete: Cascade)
  date          String
  dollars       Float
  pricePerLiter Float
  location      String
  km            Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
